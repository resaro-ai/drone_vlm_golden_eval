GEMINI_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL_ID=gemini-3.1-flash-lite-preview
GEMINI_RPM=15  # requests per minute cap; set to 0 to disable
DRONE_DEMO_ANNOTATOR=gemini
# DRONE_DEMO_ANNOTATOR=openai

# Optional OpenAI-compatible curation backend.
# Set DRONE_DEMO_ANNOTATOR=openai to use these.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.5
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1  # uncomment for a local endpoint

# Optional runtime limits for live demos. Use 0 to process all rows.
DRONE_DEMO_MAX_CURATION=0
DRONE_DEMO_MAX_AUGMENTATION=0
DRONE_DEMO_MAX_EVAL=0
DRONE_DEMO_FORCE_REFRESH=0
